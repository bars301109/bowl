# Akylman Quiz Bowl — Backend Environment Variables
# Copy this file to .env and fill in the values

# Environment
NODE_ENV=development

# Database (PostgreSQL connection string)
# On Render: use the "External Database URL" from your PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/akylman_quiz?sslmode=require

# JWT Secret (required, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (required)
ADMIN_USER=admin
ADMIN_PASSWORD=YourStrongAdminPassword123
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-change-this

# Email — Resend API (required for password reset)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Akylman Quiz <onboarding@resend.dev>

# Server
PORT=5000

# For local development, you'll need a local PostgreSQL instance
# Options:
# 1. Docker: docker run --name pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=akylman_quiz -p 5432:5432 postgres
#    Then use: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akylman_quiz?sslmode=disable
# 2. Use a cloud PostgreSQL service (Render, Supabase, Neon, etc.)
