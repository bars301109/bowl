# --- PostgreSQL Database ---
# Для локальной разработки нужен PostgreSQL. Варианты:
#
# Вариант 1 — Docker (самый простой для локальной разработки):
#   docker run --name akylman-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=akylman_quiz -p 5432:5432 postgres
#   Затем используй строку ниже (уже раскомментирована):
DATABASE_URL=postgresql://akylman:hGHvAkBE743lpa1iXDjsTHBCtHrCxbOm@dpg-d7eaabv7f7vs73efb9n0-a.oregon-postgres.render.com/quizbowl_ppn9?sslmode=require&uselibpqcompat=true
#
# Вариант 2 — Render PostgreSQL (бесплатно):
#   1. Зайди на https://dashboard.render.com
#   2. New → PostgreSQL → дай имя → Create
#   3. В настройках базы найди "External Database URL"
#   4. Вставь сюда и раскомментируй строку ниже:
# DATABASE_URL=postgresql://akylman_admin:твой-пароль@xxx-xxx-a.oregon-postgres.render.com:5432/akylman_quiz?sslmode=require
#
# Вариант 3 — Другие бесплатные хостинги:
#   • Supabase: https://supabase.com (даёт бесплатный PostgreSQL)
#   • Neon: https://neon.tech (бесплатный serverless PostgreSQL)
#   • Railway: https://railway.app (бесплатный trial)

